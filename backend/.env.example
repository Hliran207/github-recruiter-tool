# GitHub Personal Access Token (optional)
# Create one at: https://github.com/settings/tokens
# No scopes needed for read-only public data; raises rate limit to ~5,000 req/hour.
# Omit or leave blank to use the public API without auth (~60 requests/hour).
# GITHUB_TOKEN=your_github_token_here

# OpenAI API key (required for AI project assessments)
# Create one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

